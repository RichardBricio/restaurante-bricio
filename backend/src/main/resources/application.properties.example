# Server
server.port=3333

# Database (use variáveis de ambiente)
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/restaurante_bricio}
spring.datasource.username=${DB_USERNAME:postgres}
spring.datasource.password=${DB_PASSWORD:postgres}
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

# JWT
jwt.secret=${JWT_SECRET:changeme}
jwt.expiration=86400000

# External APIs (use variáveis de ambiente)
unsplash.access.key=${UNSPLASH_ACCESS_KEY:changeme}
mercadopago.access.token=${MERCADOPAGO_ACCESS_TOKEN:changeme}